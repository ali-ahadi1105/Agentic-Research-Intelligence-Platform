# ============================================================
# Research Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.

# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://research_user:CHANGE_ME@localhost:54321/research_platform?schema=public"

# ============================================================
# Authentication (JWT)
# ============================================================
# Generate a strong random string (min 32 chars):
#   openssl rand -base64 32
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_STRING_MIN_32_CHARS"

# ============================================================
# LLM Provider Configuration
# ============================================================
# Provider type: openai-compatible | anthropic | gemini
LLM_PROVIDER=openai-compatible

# OpenAI-Compatible (default)
OPENAI_API_KEY="your-api-key-here"
OPENAI_BASE_URL="http://localhost:8000/v1"
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Embedding (optional — defaults to chat provider settings)
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=3072

# Anthropic (optional)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Gemini (optional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro

# ============================================================
# Web Search (optional — requires API key)
# ============================================================
# TAVILY_API_KEY="your-tavily-api-key"

# ============================================================
# Frontend
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
