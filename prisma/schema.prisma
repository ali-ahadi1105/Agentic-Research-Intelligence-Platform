// Agentic Research Intelligence Platform - Database Schema
// SQLite version (schema-compatible with PostgreSQL + pgvector for future migration)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTHENTICATION & IDENTITY (Module 1)
// ============================================================

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String
  name            String?
  avatarUrl       String?
  role            String       @default("admin") // super_admin | admin | research_manager | analyst | viewer
  emailVerified   Boolean      @default(false)
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  memberships     OrganizationMember[]
  sessions        Session[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  apiKeys         ApiKey[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================================
// ORGANIZATIONS (Module 2) - Multi-tenant
// ============================================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     OrganizationMember[]
  workspaces  Workspace[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]
}

model OrganizationMember {
  id              String       @id @default(cuid())
  userId          String
  organizationId  String
  role            String       @default("admin") // admin | research_manager | analyst | viewer
  invitedBy       String?
  joinedAt        DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ============================================================
// WORKSPACES (Module 4) - Isolated research projects
// ============================================================

model Workspace {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  slug            String
  description     String?
  researchGoal    String?
  status          String   @default("active") // active | archived | deleted
  tags            String   @default("[]") // JSON array of tags
  color           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sources         Source[]
  entities        Entity[]
  relationships   Relationship[]
  claims          Claim[]
  timelineEvents  TimelineEvent[]
  reports         Report[]
  opportunities   Opportunity[]
  researchRuns    ResearchRun[]
  conversations   Conversation[]
  jobs            Job[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

// ============================================================
// SOURCES & DOCUMENTS (Module 6, 7) - Document Pipeline
// ============================================================

model Source {
  id             String   @id @default(cuid())
  workspaceId    String
  title          String
  type           String   // pdf | docx | txt | markdown | csv | excel | powerpoint | image | web_page | url | manual_note
  sourceUrl      String?
  mimeType       String?
  sizeBytes      Int?
  status         String   @default("pending") // pending | processing | processed | failed | reprocessing
  processingProgress Int  @default(0) // 0-100
  processingError String?
  metadata       String   @default("{}") // JSON
  language       String?
  uploadedById   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document       Document?
  evidence       Evidence[]

  @@index([workspaceId])
  @@index([status])
}

model Document {
  id             String   @id @default(cuid())
  sourceId       String   @unique
  content        String   // full extracted text
  contentCleaned String?
  language       String?
  wordCount      Int      @default(0)
  pageCount      Int?
  metadata       String   @default("{}") // JSON
  createdAt      DateTime @default(now())

  source         Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunks         Chunk[]

  @@index([sourceId])
}

model Chunk {
  id             String   @id @default(cuid())
  documentId     String
  content        String
  position       Int
  tokenCount     Int?
  // PostgreSQL pgvector extension type (384d = Xenova/all-MiniLM-L6-v2 local model)
  embedding      Unsupported("vector(384)")?
  metadata       String   @default("{}")
  createdAt      DateTime @default(now())

  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  evidence       Evidence[]

  @@index([documentId])
}

// ============================================================
// ENTITIES (Module 9) - Knowledge Extraction
// ============================================================

model Entity {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  type            String   // person | company | organization | product | technology | country | city | investment | event | patent | research_paper | website | brand | project | concept
  aliases         String   @default("[]") // JSON array
  description     String?
  attributes      String   @default("{}") // JSON object with type-specific fields
  confidence      Float    @default(0.5) // 0-1
  status          String   @default("pending") // pending | verified | rejected | disputed | merged
  mergedIntoId    String?
  sourceCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  claimEntities   ClaimEntity[]
  sourceRelations Relationship[] @relation("SourceRelations")
  targetRelations Relationship[] @relation("TargetRelations")
  timelineEvents  TimelineEvent[] @relation("TimelineEvents")

  @@index([workspaceId])
  @@index([type])
  @@index([name])
}

model Relationship {
  id              String   @id @default(cuid())
  workspaceId     String
  sourceEntityId  String
  targetEntityId  String
  type            String   // founder_of | ceo_of | employee_of | investor_in | subsidiary_of | parent_company | competitor | partner | customer | supplier | acquired | merged | collaborated | invested | member_of | located_in | owns | controls | created | supports
  attributes      String   @default("{}")
  confidence      Float    @default(0.5)
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceEntity    Entity    @relation("SourceRelations", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity    Entity    @relation("TargetRelations", fields: [targetEntityId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([sourceEntityId])
  @@index([targetEntityId])
  @@index([type])
}

// ============================================================
// CLAIMS & EVIDENCE (Module 11, 12) - Evidence-First Principle
// ============================================================

model Claim {
  id              String   @id @default(cuid())
  workspaceId     String
  statement       String
  type            String   @default("fact") // fact | assertion | prediction | opinion
  confidence      Float    @default(0.5)
  status          String   @default("pending") // pending | verified | rejected | disputed | archived
  notes           String?
  authoredBy      String   @default("ai") // ai | user:{userId}
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entities        ClaimEntity[]
  evidence        Evidence[]

  @@index([workspaceId])
  @@index([status])
}

model ClaimEntity {
  id          String   @id @default(cuid())
  claimId     String
  entityId    String
  role        String   @default("subject") // subject | object | context

  claim       Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([claimId, entityId])
  @@index([entityId])
}

model Evidence {
  id          String   @id @default(cuid())
  claimId     String
  sourceId    String?
  documentId  String?
  chunkId     String?
  excerpt     String   // The exact text snippet supporting the claim
  position    Int?     // Character position in source
  pageNumber  Int?
  confidence  Float    @default(0.7)
  authoredBy  String   @default("ai")
  createdAt   DateTime @default(now())

  claim       Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  source      Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  chunk       Chunk?   @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@index([claimId])
  @@index([sourceId])
}

// ============================================================
// TIMELINE (Module 15)
// ============================================================

model TimelineEvent {
  id            String   @id @default(cuid())
  workspaceId   String
  title         String
  description   String?
  eventDate     DateTime?
  eventDateStr  String?  // Original date string from source
  type          String   @default("event") // founding | funding | acquisition | partnership | product_launch | leadership_change | milestone | event
  category      String?
  confidence    Float    @default(0.7)
  entityId      String?  // Primary entity associated
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entity        Entity?   @relation("TimelineEvents", fields: [entityId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([eventDate])
}

// ============================================================
// REPORTS (Module 18)
// ============================================================

model Opportunity {
  id                  String   @id @default(cuid())
  workspaceId         String
  type                String   // organization_fit | investment_fit | collaboration | entry_strategy | risk_analysis | swot | pitch | decision_makers | general
  title               String
  summary             String   // Short executive summary of the analysis
  contentMarkdown     String   // Full analysis in markdown
  contentJson         String?  // Structured JSON data (optional)
  status              String   @default("generated") // generated | archived
  confidence          Float?   // Overall confidence score
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, type])
}

// ============================================================
// RESEARCH RUNS (Module 8) — Auto Research History
// ============================================================

model ResearchRun {
  id              String   @id @default(cuid())
  workspaceId     String
  userId          String?
  organizationId  String?
  goal            String?  // the research goal used
  queryCount      Int      @default(0)
  resultCount     Int      @default(0)
  pagesRead       Int      @default(0)
  sourcesCreated  Int      @default(0)
  sources         String   @default("[]") // JSON array of source info [{id,title,url}]
  summary         String?
  status          String   @default("completed") // running | completed | failed
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  durationMs      Int      @default(0)

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([startedAt])
}

model Report {
  id              String   @id @default(cuid())
  workspaceId     String
  title           String
  type            String   // executive_summary | company_report | person_report | organization_report | investment_report | market_report | research_summary | custom
  contentMarkdown String   // Full markdown content
  contentJson     String   @default("{}") // Structured sections
  status          String   @default("generated") // generating | generated | failed
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ============================================================
// AI CHAT (Module 17) - Conversational interface
// ============================================================

model Conversation {
  id            String   @id @default(cuid())
  workspaceId   String
  title         String   @default("گفتگوی جدید")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([workspaceId])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String   // user | assistant | system
  content         String
  citations       String   @default("[]") // JSON array of { claimId, evidenceId, sourceTitle, excerpt }
  confidence      Float?
  relatedEntities String   @default("[]") // JSON array of entityIds
  tokensUsed      Int?
  createdAt       DateTime @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ============================================================
// BACKGROUND JOBS (Module 58)
// ============================================================

model Job {
  id            String   @id @default(cuid())
  workspaceId   String?
  type          String   // document_processing | entity_extraction | claim_extraction | relationship_extraction | graph_building | report_generation | embedding_generation
  status        String   @default("pending") // pending | queued | running | retry | completed | failed | cancelled
  progress      Int      @default(0) // 0-100
  payload       String   @default("{}") // JSON input
  result        String?  // JSON output
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@index([type])
}

// ============================================================
// NOTIFICATIONS (Module 20)
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // job_completed | mention | research_update | system_alert
  title     String
  message   String
  data      String   @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// API KEYS (Module 25)
// ============================================================

model ApiKey {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  name            String
  keyPrefix       String   // First 8 chars of key for display
  keyHash         String   @unique
  scopes          String   @default("[]") // JSON array
  lastUsedAt      DateTime?
  isActive        Boolean  @default(true)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ============================================================
// AUDIT LOG (Module 24)
// ============================================================

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String?
  userId          String?
  action          String   // create | update | delete | approve | reject | login | logout | permission_change | model_change | settings_change | workspace_access
  resourceType    String?
  resourceId      String?
  details         String   @default("{}") // JSON
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
}

// ============================================================
// PROMPT TEMPLATES (Module 48, 69) - Versioned prompts
// ============================================================

model PromptTemplate {
  id          String   @id @default(cuid())
  key         String   // entity_extraction | claim_extraction | chat | report_executive | ...
  version     Int      @default(1)
  name        String
  description String?
  systemPrompt String
  userTemplate String?  // Optional user message template with {{variables}}
  variables   String   @default("[]")  // JSON array of variable names
  model       String   @default("default")
  temperature Float    @default(0.3)
  maxTokens   Int      @default(2000)
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, version])
  @@index([key])
  @@index([isActive])
}

// ============================================================
// MODEL PROVIDERS (Module 47) - User-configured LLM providers
// ============================================================

model ModelProvider {
  id            String   @id @default(cuid())
  organizationId String
  label         String   // User-friendly name (e.g., "My vLLM Server")
  type          String   // openai-compatible | openai | anthropic | gemini
  apiKey        String   // Encrypted in production (here plaintext for simplicity)
  baseUrl       String?
  chatModel     String   // e.g., gpt-4o-mini, claude-3-5-sonnet, gemini-1.5-pro
  embeddingModel String?
  isActive      Boolean  @default(true)
  isDefault     Boolean  @default(false)  // Use this provider for all operations
  useForChat    Boolean  @default(true)
  useForEmbeddings Boolean @default(false)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([organizationId])
  @@index([isDefault])
}
